    <!-- ── Extension fallbacks ────────────────────────────────────────────────── -->

    <!-- Any .pem file not matched above gets a generic size-scaled PEM block. -->
    <template extension=".pem" type="pem" pemLabel="PRIVATE KEY" />

    <template extension=".json"><![CDATA[
{
  "synthetic": true,
  "generator": "SimpleProvider"
}
]]></template>

    <template extension=".csv"><![CDATA[
column1,column2,column3
value1,value2,value3
]]></template>

  </syntheticTemplates>
</configuration>