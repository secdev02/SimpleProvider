<?xml version="1.0" encoding="utf-8"?>
<!--
  <exe-name>.exe.config
  Must be placed in the same directory as the exe and named to match:
    SimpleProvider_Synthetic.exe  →  SimpleProvider_Synthetic.exe.config

  SECTIONS
    <syntheticFileList>   – the virtual file tree (replaces the external CSV file)
    <syntheticTemplates>  – content returned when synthetic files are read

  Edit and restart the provider; no recompile is needed.
-->
<configuration>

  <!--
    Virtual file system layout.
    Format per line: \Path\To\Entry,isDirectory,fileSize,unixTimestamp
      isDirectory   : true | false
      fileSize      : bytes (use 0 for directories)
      unixTimestamp : seconds since Unix epoch – applied to all four NTFS timestamps

    Rules:
      - Lines beginning with # are comments.
      - Blank lines are ignored.
      - Parent directories must appear before their children.
  -->
  <syntheticFileList><![CDATA[
\AWS,true,0,1743942586
\AWS\credentials,false,116,1741508986
\AWS\config,false,94,1739636986
\AWS\iam_access_keys.csv,false,198,1744586986
\AWS\s3_bucket_policy.json,false,1243,1736177386

\SSH Keys,true,0,1751527786
\SSH Keys\id_rsa,false,1675,1738927786
\SSH Keys\id_rsa.pub,false,381,1738927786
\SSH Keys\id_ed25519,false,411,1740680986
\SSH Keys\id_ed25519.pub,false,107,1740680986
\SSH Keys\authorized_keys,false,762,1736926186
\SSH Keys\deploy_key.pem,false,1704,1742354986

\API Keys,true,0,1744586986
\API Keys\api_keys.json,false,847,1748708986
\API Keys\github_pat.txt,false,93,1745674186
\API Keys\stripe_keys.txt,false,312,1749252586
]]></syntheticFileList>

  <!--
    Content templates for synthetic projected files.

    TEMPLATE ELEMENT
      name="filename"             Exact filename match (case-insensitive).
      extension=".ext"            File extension fallback when no exact name matches.
      type="pem"                  Generate a deterministic PEM block sized to fileSize.
      pemLabel="RSA PRIVATE KEY"  Label inside the BEGIN/END markers (type="pem" only).
      (CDATA content)             Static text; trimmed then padded/truncated to fileSize.

    LOOKUP ORDER
      1. Exact name match
      2. Extension fallback
      3. Generic "# filename / synthetic file" comment (built-in, no config needed)
  -->
  <syntheticTemplates>

    <!-- ── AWS ──────────────────────────────────────────────────────────────── -->

    <template name="credentials"><![CDATA[
[default]
aws_access_key_id = AKIAIOSFODNN7EXAMPLE
aws_secret_access_key = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
]]></template>

    <template name="config"><![CDATA[
[default]
region = us-east-1
output = json

[profile staging]
region = us-west-2
output = text

[profile prod]
region = eu-west-1
output = json
]]></template>

    <template name="iam_access_keys.csv"><![CDATA[
User Name,Access key ID,Secret access key,Status,Created
admin,AKIAIOSFODNN7EXAMPLE,wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY,Active,2024-01-15
deploy,AKIAI44QH8DHBEXAMPLE,je7MtGbClwBF/2Zp9Utk/h3yCo8nvbEXAMPLEKEY,Active,2024-03-01
]]></template>

    <template name="s3_bucket_policy.json"><![CDATA[
{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowRootAndAdminAccess",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::123456789012:root",
                    "arn:aws:iam::123456789012:user/admin"
                ]
            },
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::example-company-backups",
                "arn:aws:s3:::example-company-backups/*"
            ]
        },
        {
            "Sid": "DenyUnencryptedObjectUploads",
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::example-company-backups/*",
            "Condition": {
                "StringNotEquals": {
                    "s3:x-amz-server-side-encryption": "AES256"
                }
            }
        },
        {
            "Sid": "AllowCrossAccountRead",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::987654321098:role/ReadOnlyRole"
            },
            "Action": ["s3:GetObject", "s3:ListBucket"],
            "Resource": [
                "arn:aws:s3:::example-company-backups",
                "arn:aws:s3:::example-company-backups/*"
            ]
        }
    ]
}
]]></template>

    <!-- ── SSH Keys – private keys are size-scaled PEM blocks ────────────────── -->

    <template name="id_rsa"         type="pem" pemLabel="RSA PRIVATE KEY" />
    <template name="id_ed25519"     type="pem" pemLabel="OPENSSH PRIVATE KEY" />
    <template name="deploy_key.pem" type="pem" pemLabel="RSA PRIVATE KEY" />

    <template name="id_rsa.pub"><![CDATA[
ssh-rsa  admin@prod-server
]]></template>

    <template name="id_ed25519.pub"><![CDATA[
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGpTX9kMqzR7vE4pLhNbDgCm2wH3FjKsP0uYxRnVt8Qo user@example-host
]]></template>

    <template name="authorized_keys"><![CDATA[
ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC7e1bXAklV8kGvFLkv0NCHnfRakXS3w2fBWHCpWJCjVp6eLI3YJFTvX9z5JIFAYTmXW6r7M0cHZNrKs8DCFx9mTCH6bQp1YJUvC3m8Xz4vNFn5T7b9HhXFCp3w1JKEjgQkTb5LMD2Jf9kMn2oYrWjHcBpTuZsVKlIe admin@prod-server
ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQDm3pK7LrXnV5tBs8WqNzJ9PeYc4FhOkM2iVgRdCbHlTsUwXnAJ6mDpY8FjLqKvGzEo7tN1cWrXsMbVaHpeFd3KcR5nJW2oLhTgI8mBpD4qNsYvXkZcFwO6eA9jUxRnKHlGmP2oQrTsEbVpZsWKlIeQdFxOyRmAgEbJ5 deploy@ci-runner
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGpTX9kMqzR7vE4pLhNbDgCm2wH3FjKsP0uYxRnVt8Qo backup@monitoring
ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC5f2cYBmkW6tHuX3sAr7VnOfZd5GiPlN3jUhScDaIkEsRwYoAL8nEqX6FkMpL7vJhDo5tO2bXrTmCwAIqeFe4LdS6oKJ3mBuEhH9nQsPwJ7vAkN4bRxOzSmFhMp8tV developer@workstation
]]></template>

    <!-- ── API Keys ──────────────────────────────────────────────────────────── -->

