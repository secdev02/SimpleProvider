    <template name="github_pat.txt"><![CDATA[
ghp_EXAMPLE1234567890abcdefghijklmnopqrstuvwxyz12
Created: 2024-01-15
Scopes: repo, workflow, read:org
]]></template>

    <template name="stripe_keys.txt"><![CDATA[
